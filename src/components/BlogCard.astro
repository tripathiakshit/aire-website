---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  image?: string;
  tags?: string[];
}

const { title, description, pubDate, slug, image, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
  {image ? (
    <div class="h-52 overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    </div>
  ) : (
    <div class="h-52 bg-gradient-to-br from-geo-primary to-geo-slate flex items-center justify-center">
      <span class="font-display text-white/30 text-3xl font-bold italic">AI Resource Exploration</span>
    </div>
  )}
  <div class="p-6 flex flex-col flex-1 border-t-2 border-transparent group-hover:border-geo-gold transition-colors duration-300">
    <time class="text-geo-gold text-xs font-semibold uppercase tracking-[0.1em] mb-3 block">{formattedDate}</time>
    <h3 class="font-display text-geo-primary text-xl font-bold mb-2 leading-snug">{title}</h3>
    <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-4">{description}</p>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {tags.map(tag => (
          <span class="bg-geo-primary/8 text-geo-primary text-xs px-2.5 py-1 rounded-full font-medium">
            {tag}
          </span>
        ))}
      </div>
    )}
    <a href={`/blog/${slug}`} class="text-geo-gold font-semibold text-sm hover:text-amber-600 transition-colors">
      Read more →
    </a>
  </div>
</article>
