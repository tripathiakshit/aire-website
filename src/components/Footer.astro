---
const quickLinks = [
  { href: '/services', label: 'Services' },
  { href: '/cage-in', label: 'CAGE-IN' },
  { href: '/projects', label: 'Projects' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/publications', label: 'Publications' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-geo-slate text-white">
  <!-- Gold top accent -->
  <div class="h-1 bg-geo-gold"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-10">
      <!-- Column 1: Brand (full width on mobile) -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <img src="/assets/AIRE-logo-long.jpg" alt="AI Resource Exploration Logo" class="h-10 w-auto brightness-0 invert" width="1181" height="147" />
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          AI-powered mineral exploration consultancy. 26+ years of multidisciplinary expertise across five continents.
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="font-display text-sm font-semibold text-geo-gold uppercase tracking-[0.15em] mb-4 md:mb-5">Navigation</h3>
        <ul class="grid grid-cols-2 md:grid-cols-1 gap-x-4 gap-y-2 md:gap-y-2.5">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-slate-400 hover:text-white text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="font-display text-sm font-semibold text-geo-gold uppercase tracking-[0.15em] mb-5">Contact</h3>
        <div class="space-y-2 text-slate-400 text-sm">
          <p class="text-white font-medium">Dr. Amit Tripathi</p>
          <p>Principal Consultant</p>
          <p>AI Resource Exploration</p>
          <a
            href="/contact"
            class="inline-block mt-4 px-5 py-2.5 bg-geo-gold text-white text-sm font-semibold rounded hover:bg-amber-500 transition-colors"
          >
            Get in Touch →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-slate-500 text-xs">© {new Date().getFullYear()} AI Resource Exploration. All rights reserved.</p>
      <p class="text-slate-600 text-xs uppercase tracking-wider">AI-Powered Mineral Exploration</p>
    </div>
  </div>
</footer>
