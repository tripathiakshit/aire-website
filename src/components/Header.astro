---
import { Menu, X } from 'lucide-astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/cage-in', label: 'CAGE-IN' },
  { href: '/projects', label: 'Projects' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/team', label: 'Team' },
  { href: '/publications', label: 'Blogs & Publications' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header id="site-header" class="sticky top-0 z-50 bg-geo-slate shadow-md shadow-black/30 transition-shadow duration-300">
  <!-- Gold accent stripe -->
  <div class="h-1 bg-geo-gold"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img src="/assets/AIRE-logo-long.jpg" alt="AI Resource Exploration Logo" class="h-9 lg:h-11 w-[220px] sm:w-auto object-contain object-left" width="1181" height="147" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm font-medium tracking-wide transition-colors ${
              isActive(link.href)
                ? 'text-geo-secondary'
                : 'text-slate-400 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class={`ml-3 px-5 py-2.5 text-sm font-semibold rounded transition-colors ${
            isActive('/contact')
              ? 'bg-geo-primary text-white'
              : 'bg-geo-gold text-white hover:bg-amber-500'
          }`}
        >
          Contact
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        class="lg:hidden p-2 rounded text-slate-400 hover:text-white hover:bg-white/10 transition-colors"
      >
        <span id="menu-icon-open"><Menu size={22} /></span>
        <span id="menu-icon-close" class="hidden"><X size={22} /></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (height animated via CSS in global.css) -->
  <div id="mobile-menu" class="lg:hidden border-t border-white/10 bg-geo-slate">
    <nav class="px-4 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-3 py-2.5 text-sm font-medium tracking-wide transition-colors rounded ${
            isActive(link.href)
              ? 'text-geo-secondary bg-white/10'
              : 'text-slate-300 hover:text-white hover:bg-white/5'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class={`mt-2 px-4 py-3 text-sm font-semibold text-white text-center rounded transition-colors ${isActive('/contact') ? 'bg-geo-primary' : 'bg-geo-gold hover:bg-amber-500'}`}
      >
        Contact
      </a>
    </nav>
  </div>
</header>

<!-- Sticky bottom CTA — slides up after scrolling 600px (hidden on /contact) -->
<div
  id="sticky-cta-bar"
  class="fixed bottom-0 inset-x-0 z-40 bg-geo-gold text-geo-primary-dark py-2.5 sm:py-3 px-3 sm:px-6 flex items-center justify-center gap-3 sm:gap-6 shadow-2xl translate-y-full transition-transform duration-300"
  role="complementary"
  aria-label="Project inquiry prompt"
>
  <span class="hidden sm:inline text-geo-primary-dark text-sm font-bold">Have a project in mind?</span>
  <a href="/contact" class="px-4 py-1.5 rounded bg-geo-primary-dark text-white font-bold text-xs uppercase tracking-wider hover:bg-geo-primary transition-colors whitespace-nowrap shadow-sm">Submit a Brief</a>
  <a href="/contact#cal-inline-embed" class="px-4 py-1.5 rounded border-2 border-geo-primary-dark text-geo-primary-dark font-bold text-xs uppercase tracking-wider hover:bg-geo-primary-dark hover:text-white transition-colors whitespace-nowrap">Schedule a Call</a>
  <button id="dismiss-sticky-cta" aria-label="Dismiss" class="absolute right-3 top-1/2 -translate-y-1/2 text-geo-primary-dark/60 hover:text-geo-primary-dark transition-colors text-sm leading-none font-bold">✕</button>
</div>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  // Header shadow on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-lg');
    } else {
      header?.classList.remove('shadow-lg');
    }
  }, { passive: true });

  // Mobile menu toggle — uses CSS max-height transition (see global.css)
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('open');
    if (isOpen) {
      menu?.classList.remove('open');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.add('open');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // Sticky CTA bar
  const stickyCta = document.getElementById('sticky-cta-bar');
  const dismissBtn = document.getElementById('dismiss-sticky-cta');
  const isContactPage = window.location.pathname.startsWith('/contact');
  const dismissed = sessionStorage.getItem('sticky-cta-dismissed');

  if (stickyCta && !isContactPage && !dismissed) {
    let shown = false;
    window.addEventListener('scroll', () => {
      if (!shown && window.scrollY > 600) {
        stickyCta.classList.remove('translate-y-full');
        shown = true;
      }
    }, { passive: true });

    dismissBtn?.addEventListener('click', () => {
      stickyCta.classList.add('translate-y-full');
      sessionStorage.setItem('sticky-cta-dismissed', '1');
    });
  }
</script>
