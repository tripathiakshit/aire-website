---
interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
  {image ? (
    <div class="h-48 overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  ) : (
    <div class="h-48 bg-gradient-to-br from-geo-primary/10 to-geo-secondary/30 flex items-center justify-center">
      <div class="w-12 h-12 rounded-full bg-geo-primary/10 flex items-center justify-center">
        <div class="w-5 h-5 rounded-full bg-geo-primary/30"></div>
      </div>
    </div>
  )}
  <div class="p-6 flex flex-col flex-1 border-t-2 border-transparent group-hover:border-geo-gold transition-colors duration-300">
    <h3 class="font-display text-geo-primary text-lg font-semibold mb-2 leading-snug">{title}</h3>
    <p class="text-slate-500 text-sm leading-relaxed flex-1">{description}</p>
  </div>
</div>
