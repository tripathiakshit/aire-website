---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Scroll-triggered reveal for [data-reveal] elements
  // Use requestAnimationFrame to ensure layout is complete before observing
  requestAnimationFrame(() => {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.05 });
    document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));

    // Safety fallback: reveal any elements still hidden after 2.5s
    setTimeout(() => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach(el => {
        el.classList.add('is-visible');
      });
    }, 2500);
  });

  // Animated stat counters for [data-count-to] elements
  // Ensure the counter always displays the correct final value
  const countEls = document.querySelectorAll('[data-count-to]');
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    requestAnimationFrame(() => {
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          if (el.dataset.countAnimated) return; // prevent double-fire
          el.dataset.countAnimated = '1';
          const target = parseInt(el.dataset.countTo ?? '0');
          const suffix = el.dataset.countSuffix ?? '';
          const duration = 1200;
          const start = performance.now();
          const step = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
            el.textContent = Math.round(eased * target) + suffix;
            if (progress < 1) {
              requestAnimationFrame(step);
            } else {
              el.textContent = target + suffix; // guarantee final value
            }
          };
          requestAnimationFrame(step);
          counterObserver.unobserve(el);
        });
      }, { threshold: 0.3 });
      countEls.forEach(el => counterObserver.observe(el));
    });

    // Safety fallback: ensure counters show correct values after 4s
    setTimeout(() => {
      countEls.forEach(el => {
        const htmlEl = el as HTMLElement;
        if (!htmlEl.dataset.countAnimated) {
          const target = htmlEl.dataset.countTo ?? '0';
          const suffix = htmlEl.dataset.countSuffix ?? '';
          htmlEl.textContent = target + suffix;
        }
      });
    }, 4000);
  }
</script>
