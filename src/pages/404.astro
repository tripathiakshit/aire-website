---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Page Not Found — AI Resource Exploration"
  description="The page you're looking for doesn't exist. Return to AI Resource Exploration's homepage."
>
  <section class="min-h-[60vh] flex items-center justify-center bg-geo-deep text-white">
    <div class="max-w-xl mx-auto px-6 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-4">Error 404</p>
      <h1 class="font-display text-5xl md:text-7xl font-bold mb-6">Page Not Found</h1>
      <p class="text-slate-400 text-lg leading-relaxed mb-10">
        The page you're looking for may have been moved or doesn't exist. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="w-full sm:w-auto px-8 py-4 rounded bg-geo-gold text-white font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors text-center"
        >
          Back to Homepage
        </a>
        <a
          href="/contact"
          class="w-full sm:w-auto px-8 py-4 rounded border-2 border-white/30 text-white font-medium text-sm uppercase tracking-wider hover:bg-white hover:text-geo-primary transition-all duration-200 text-center"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</PageLayout>
