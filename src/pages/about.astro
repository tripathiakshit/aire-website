---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import amitTripathiImg from '../assets/amit_tripathi.jpg';
---

<PageLayout
  title="About — AI Resource Exploration"
  description="About Dr. Amit Tripathi — Founder of AI Resource Exploration, structural geologist with 26+ years of international mineral exploration experience."
>
  <!-- Page Hero -->
  <section class="relative bg-geo-slate text-white py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">The Expert Behind the Work</p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4">Dr. Amit Tripathi</h1>
      <p class="text-slate-400 text-lg">Founder & Principal Consultant, AI Resource Exploration</p>
    </div>
  </section>

  <!-- Stats Row -->
  <section class="bg-geo-primary text-white py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-reveal>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-geo-gold" data-count-to="30" data-count-suffix="+">30+</p>
          <p class="text-blue-200/70 text-xs uppercase tracking-[0.15em] mt-2">Years Experience</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-geo-gold" data-count-to="20" data-count-suffix="+">20+</p>
          <p class="text-blue-200/70 text-xs uppercase tracking-[0.15em] mt-2">Countries</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-geo-gold" data-count-to="22" data-count-suffix="+">22+</p>
          <p class="text-blue-200/70 text-xs uppercase tracking-[0.15em] mt-2">Publications</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-geo-gold">Ph.D.</p>
          <p class="text-blue-200/70 text-xs uppercase tracking-[0.15em] mt-2">Structural Geology</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Bio Section -->
  <section class="py-20 bg-geo-deep">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-14">
        <!-- Photo -->
        <div class="flex justify-center lg:justify-start lg:pt-4">
          <div class="relative">
            <div class="absolute -inset-2 rounded-full bg-geo-secondary/20"></div>
            <Image
              src={amitTripathiImg}
              alt="Dr. Amit Tripathi"
              width={256}
              class="relative w-52 h-52 sm:w-64 sm:h-64 rounded-full object-cover shadow-xl border-4 border-white"
            />
          </div>
        </div>

        <!-- Bio Text -->
        <div class="lg:col-span-2">
          <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.2em] mb-3">Biography</p>
          <h2 class="font-display text-3xl text-white mb-1">Dr. Amit Tripathi</h2>
          <p class="text-slate-400 text-sm mb-6 font-medium">Ph.D. Structural Geology &nbsp;·&nbsp; Member AusIMM &nbsp;·&nbsp; <a href="https://www.linkedin.com/in/amit-tripathi-b7a5567/" target="_blank" rel="noopener noreferrer" class="text-geo-secondary hover:text-white transition-colors">LinkedIn ↗</a></p>

          <div class="mb-6 p-4 border-l-4 border-geo-gold bg-amber-900/10 rounded-r">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-geo-gold mb-2">Qualifications</h3>
            <ul class="text-slate-300 text-sm space-y-1">
              <li>Ph.D., Geology — BHU, India</li>
              <li>M.Sc., Geology (Structural Geology specialization) — BHU, India</li>
            </ul>
          </div>


          <div class="space-y-4 text-slate-300 leading-relaxed text-[15px]">
            <p>
              Dr. Amit has multidisciplinary experience in mineral and nuclear energy exploration, mine planning, processing, and geo-statistical quality control across a variety of minerals — high-value minerals, base metals, and industrial minerals — recognized through his membership of the Australasian Institute of Mines and Metals (AusIMM).
            </p>
            <p>
              His experience spans twenty-six years across research, exploration, and mining industries in several countries on five continents — USA, Australia, Canada, Colombia, Ecuador, Guyana, India, Madagascar, Mongolia, Nicaragua, Niger, Panama, Senegal, South Africa, and Tanzania.
            </p>
            <p>
              Dr. Tripathi is a Doctorate in Structural Geology who founded AI Resource Exploration, providing end-to-end services in the fields of Mining, Mineral Exploration, and Mineral Processing.
            </p>
            <p>
              He served the National Mineral Development Corporation (NMDC), one of the top ten public sector companies of the Government of India, for seven years in various capacities — including as project manager in Tanzania and Lesotho, leading the team in Africa to a successful hard rock exploration project. During this time he also completed exploration of diamond-bearing kimberlites in South India.
            </p>
            <p>
              He has served in senior management and advisory positions, preparing NI43-101 and JORC compliant reports for several listed companies including Goviex Uranium Ltd. (Canada), Sunward Resources Ltd. (Canada), Condoto Platinum Ltd (Australia), Future Vantage (Singapore) Pvt. Ltd., and Blue Stream Enterprises Ltd. (BVI).
            </p>
            <p>
              Dr. Tripathi has worked on structural correlations of mineralization and developed a mathematical model for assessment of gold grades in coarse gold deposits and high nugget effect geological environments.
            </p>
            <p>
              He has authored one book and published approximately twenty-two scientific research papers in national and international journals — internationally recognized and referenced in gold, diamond, and iron ore exploration works.
            </p>
            <p>
              International analysts including Ticker Trax (Thom Calandra) and 321Gold (Bob Moriarty) have reviewed and written about his work. In 1992, he was awarded the prestigious Dr. K.S. Krishnan Fellowship by the Dept. of Atomic Energy.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Corporate Structure & Independence -->
  <section class="py-16 bg-geo-slate border-t border-white/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-3">Transparency & Independence</p>
      <h2 class="font-display text-2xl text-white mb-8">Corporate Structure & Independence Statement</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white/5 rounded-lg p-6 border border-white/10">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-geo-secondary mb-3">Legal Entity</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3">
            <strong>AI Resource Exploration (AIRE)</strong> is the sole operating entity for all exploration consulting, CAGE-IN services, and resource evaluation work. Founded by Dr. Amit Tripathi in 2017, AIRE is registered in India (registered office: 1310 Amethyst, My Home Jewel, Madinaguda, Hyderabad 500049, Telangana). Dr. Tripathi holds a 96% controlling equity interest.
          </p>
          <p class="text-slate-300 text-sm leading-relaxed">
            <strong>GeoExploration LLC</strong> is a Florida-registered company founded by Dr. Tripathi in 2012. Following India tax reforms in 2017, all active business was consolidated into AIRE. GeoExploration LLC is currently dormant; the <em>geoexplorationllc.com</em> email address is retained for continuity and routes to the same team.
          </p>
        </div>

        <div class="bg-white/5 rounded-lg p-6 border border-white/10">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-geo-secondary mb-3">Independence Statement</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3">
            AIRE's technical reports and professional opinions are prepared on an independent, fee-for-service basis. AIRE does not solicit or accept referral fees from third parties in connection with client projects.
          </p>
          <p class="text-slate-300 text-sm leading-relaxed">
            AIRE may hold a minor equity interest in projects where it has participated in founding, or where a listed-company client has offered equity as partial compensation. Any such interest is disclosed to all affected parties prior to engagement.
          </p>
        </div>
      </div>

      <div class="p-4 bg-geo-primary/10 rounded border border-geo-primary/20 text-sm text-slate-300 leading-relaxed">
        AIRE's work is independently verifiable: Dr. Tripathi has prepared NI 43-101 and JORC compliant reports for several publicly listed companies including GoviEx Uranium Ltd. (Canada), Sunward Resources Ltd. (Canada), and Condoto Platinum Ltd. (Australia), among others — all referenced in public regulatory filings and company news releases.
      </div>
    </div>
  </section>

  <!-- Team teaser -->
  <section class="py-14 bg-geo-deep">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-3">The People Behind Our Work</p>
      <h2 class="font-display text-3xl md:text-4xl text-white mb-4">Our Team</h2>
      <p class="text-slate-400 max-w-2xl mx-auto leading-relaxed mb-4">
        AIRE is led by Dr. Tripathi and operates through a trusted network of specialist geologists, geophysicists, remote sensing experts, resource modellers, and senior advisors — assembled on a project basis to match the right expertise to each engagement. This model allows us to bring 15+ specialists across five continents to bear on a project without the overhead of a large permanent staff.
      </p>
      <a href="/team" class="inline-block bg-geo-primary text-white px-8 py-3.5 rounded font-semibold text-sm uppercase tracking-wider hover:bg-geo-primary-dark transition-colors">
        Meet Our Team →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-geo-slate text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Work With Us</p>
      <h2 class="font-display text-4xl font-bold mb-6">Ready to discuss your project?</h2>
      <a href="/contact" class="inline-block bg-geo-gold text-white px-10 py-4 rounded font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors">
        Get in Touch
      </a>
    </div>
  </section>
</PageLayout>
