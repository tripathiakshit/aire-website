---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PageLayout from '../layouts/PageLayout.astro';

import case1aImg from '../assets/case1-1-2.jpg';
import case1bImg from '../assets/case1-2.jpg';
import case2aImg from '../assets/case2-1.png';
import case2bImg from '../assets/case2-2.png';
import case3aImg from '../assets/case3-1.png';
import case3bImg from '../assets/case3-2.png';
import case4aImg from '../assets/case4-1-1.png';
import case4bImg from '../assets/case4-2.png';

const caseStudies: Array<{
  number: string;
  type: string;
  images: Array<{ src: ImageMetadata; alt: string }>;
  before: string;
  after: string;
  bg: string;
  timeline?: Array<{ marker: string; event: string }>;
}> = [
  {
    number: '01',
    type: 'Copper-Gold Porphyry',
    images: [
      { src: case1aImg, alt: 'Copper-Gold Porphyry — site overview' },
      { src: case1bImg, alt: 'Copper-Gold Porphyry — drill results' },
    ],
    before: 'Gold production dating back to the 1920s. Over 3 million ounces of gold produced from manto-type, fault-vein-hosted, and disconformity-related high-grade underground ore bodies. In the 2000s a gold-copper porphyry was found just west of the old gold mine and a resource drilling program started. About 3 Moz Au-eq resources were identified by 2010.',
    after:  'The project database was reanalyzed using CAGE-IN technology. The study successfully identified additional porphyries and drill targets. Within two years the resources more than tripled to over 12.8 Moz Au-eq — equivalent to over $3.5 billion in-situ gold value at 2025 prices.',
    bg: 'bg-white',
    timeline: [
      { marker: 'Q3 2009', event: 'Project acquired' },
      { marker: 'Q1 2010', event: 'Exploration programme started' },
      { marker: 'Q4 2010', event: 'CAGE-IN introduced' },
      { marker: 'Q3 2011', event: 'Maiden resource of 11.7 Moz Au-eq declared' },
      { marker: '2012', event: 'Resource upgraded to over 13 Moz Au-eq' },
    ],
  },
  {
    number: '02',
    type: 'Skarn Deposit',
    images: [
      { src: case2aImg, alt: 'Skarn Deposit — geophysics before CAGE-IN' },
      { src: case2bImg, alt: 'Skarn Deposit — targets after CAGE-IN' },
    ],
    before: 'Operating gold-silver mine in a skarn adjacent to a granitic intrusive. Geophysical signatures of mineralization were very weak and could not be used to identify or expand mineralization trends.',
    after:  'CAGE-IN technology successfully defined the mineralization signature by combining multiple layers of data. Mineralization signatures became visible in geophysics and new similar signatures were identified NW of the existing mine, providing immediate drill targets for brownfield resource expansion.',
    bg: 'bg-slate-50',
  },
  {
    number: '03',
    type: 'Epithermal Gold',
    images: [
      { src: case3aImg, alt: 'Epithermal Gold — indistinguishable signatures before' },
      { src: case3bImg, alt: 'Epithermal Gold — defined signatures after CAGE-IN' },
    ],
    before: 'Operating epithermal gold mine had indistinguishable geophysical signatures — no contrast between ore and waste. The weak contrast could not be used to identify or expand mineralization trends.',
    after:  'CAGE-IN technology successfully defined the mineralization signature combining multiple layers of data. Mineralization signatures became visible in geophysics and new similar signatures were identified along strike of the existing mine, providing immediate drill targets for brownfield resource expansion.',
    bg: 'bg-white',
  },
  {
    number: '04',
    type: 'Greenfield Nickel Laterite',
    images: [
      { src: case4aImg, alt: 'Greenfield Nickel Laterite — regional dataset' },
      { src: case4bImg, alt: 'Greenfield Nickel Laterite — identified targets' },
    ],
    before: 'Reconnaissance for nickel laterite was to be conducted over 1,000 km² with no previous history of nickel mining or mineralization. Available datasets were regional geophysical surveys and remote sensing data.',
    after:  'Using CAGE-IN, multiple geological datasets were analyzed together. Theoretical geological concepts were applied and nickel targets were defined per metallogenic theory. Several Ni targets were identified, field-checked, and rapidly developed into drill targets. The area is still being explored but several interesting drill intercepts and resource zones have already been identified.',
    bg: 'bg-slate-50',
    timeline: [
      { marker: 'Q2 2021', event: 'CAGE-IN introduced; regional data analysed' },
      { marker: 'Q3 2022', event: 'Resource report completed — multi-million tonne Ni discovery' },
    ],
  },
];
---

<PageLayout
  title="Case Studies — AI Resource Exploration"
  description="Real-world results showing how CAGE-IN technology has transformed mineral exploration outcomes, tripling resource estimates and identifying new targets."
>

  <!-- Page Hero -->
  <section class="relative bg-geo-slate text-white py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Real-World Results</p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4">Case Studies</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        How CAGE-IN technology has transformed mineral exploration outcomes for our clients.
      </p>
    </div>
  </section>

  <!-- Confidentiality note -->
  <section class="bg-white border-b border-slate-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex gap-5 items-start">
      <div class="shrink-0 mt-0.5 w-9 h-9 rounded-full bg-geo-primary/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-geo-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <div>
        <p class="font-semibold text-geo-primary text-sm mb-1">Why We Cannot Name Our Clients</p>
        <p class="text-slate-500 text-sm leading-relaxed">
          All clients are covered by mandatory mutual NDAs. We do not disclose company names, project names, or jurisdictions without explicit written consent — this is the same confidentiality we would extend to your data. The outcomes described below are real; the identities are protected. For due diligence purposes, we can arrange a reference call with past clients who have agreed to speak confidentially. <a href="/contact" class="text-geo-primary underline underline-offset-2 hover:text-geo-gold transition-colors">Contact us to request a reference call →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  {caseStudies.map((study) => (
    <section class={`${study.bg} py-16 md:py-20`}>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Case header -->
        <div class="flex items-center gap-5 mb-10">
          <span class="font-display text-6xl font-bold text-geo-primary/10 leading-none select-none">{study.number}</span>
          <div>
            <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-1">Case Study {study.number}</p>
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-geo-slate">{study.type}</h2>
          </div>
        </div>

        <!-- Two-column layout: narrative left, images right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

          <!-- Narrative -->
          <div class="space-y-6">

            <!-- Before -->
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <div class="inline-flex items-center gap-2 mb-3">
                <span class="bg-geo-slate text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">Before CAGE-IN</span>
              </div>
              <p class="text-slate-600 leading-relaxed text-sm">{study.before}</p>
            </div>

            <!-- After -->
            <div class="rounded-xl border border-geo-gold/30 bg-amber-50 p-6 shadow-sm">
              <div class="inline-flex items-center gap-2 mb-3">
                <span class="bg-geo-gold text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">After CAGE-IN</span>
              </div>
              <p class="text-slate-700 leading-relaxed text-sm">{study.after}</p>
            </div>

            {study.timeline && (
              <div class="rounded-xl border border-geo-primary/20 bg-geo-primary/5 p-6">
                <p class="text-xs font-semibold uppercase tracking-wider text-geo-primary mb-4">Project Timeline</p>
                <ol class="relative border-l border-geo-primary/20 space-y-4 ml-2">
                  {study.timeline.map((step) => (
                    <li class="pl-5">
                      <span class="absolute -left-[7px] mt-1 w-3.5 h-3.5 rounded-full border-2 border-geo-primary bg-white"></span>
                      <p class="text-xs font-semibold text-geo-primary">{step.marker}</p>
                      <p class="text-sm text-slate-600">{step.event}</p>
                    </li>
                  ))}
                </ol>
              </div>
            )}

          </div>

          <!-- Images -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {study.images.map((img) => (
              <Image
                src={img.src}
                alt={img.alt}
                width={500}
                class="w-full h-52 object-cover rounded-xl shadow-md"
              />
            ))}
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-20 bg-geo-slate text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">See It In Action</p>
      <h2 class="font-display text-4xl font-bold mb-4">Ready to Transform Your Exploration?</h2>
      <p class="text-slate-400 mb-10 max-w-xl mx-auto">
        Learn how CAGE-IN technology works or get in touch to discuss your project.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/cage-in"
          class="inline-block bg-geo-gold text-white px-10 py-4 rounded font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors"
        >
          Explore CAGE-IN
        </a>
        <a
          href="/contact"
          class="inline-block border border-white/30 text-white px-10 py-4 rounded font-semibold text-sm uppercase tracking-wider hover:bg-white/10 transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

</PageLayout>
