---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact Us — AI Resource Exploration"
  description="Contact AI Resource Exploration to discuss your mineral exploration project. Submit a project inquiry or book a discovery call directly with Dr. Amit Tripathi."
>
  <!-- Page Hero -->
  <section class="relative bg-geo-slate text-white py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Start the Conversation</p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4">Contact Us</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Submit a project inquiry below — or skip straight to booking a discovery call with Dr. Amit Tripathi.
      </p>
    </div>
  </section>

  <!-- Project Inquiry Section -->
  <section class="py-12 md:py-16 bg-geo-slate text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- Right: Project inquiry form — ORDER FIRST on mobile -->
        <div class="order-1 lg:order-2 bg-white rounded-2xl p-5 sm:p-8">
          <p class="font-display text-xl text-geo-primary font-semibold mb-1">Submit a Project Inquiry</p>
          <p class="text-slate-500 text-sm mb-4">Tell us what you need — we'll get back to you with a tailored offer within 2 working days.</p>

          <!-- Trust signals -->
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs font-medium text-slate-500 border border-slate-200 rounded px-2.5 py-1">GoviEx Uranium — NI 43-101</span>
            <span class="text-xs font-medium text-slate-500 border border-slate-200 rounded px-2.5 py-1">Sunward Resources — JORC</span>
            <span class="text-xs font-medium text-slate-500 border border-slate-200 rounded px-2.5 py-1">Condoto Platinum — JORC</span>
          </div>
          <p class="text-xs text-slate-400 mb-5">Some of the major exploration successes to which we contributed</p>

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            enctype="multipart/form-data"
            class="space-y-4"
          >
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" name="bot-field" class="hidden" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Your Name <span class="text-red-400">*</span></label>
                <input type="text" id="name" name="name" required maxlength="100" placeholder="Dr. Jane Smith" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Email Address <span class="text-red-400">*</span></label>
                <input type="email" id="email" name="email" required maxlength="100" placeholder="you@company.com" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Phone <span class="text-slate-400 font-normal normal-case">(optional)</span></label>
                <input type="tel" id="phone" name="phone" maxlength="20" placeholder="+1 514 000 0000" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
              </div>
              <div>
                <label for="company-website" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Company Website <span class="text-slate-400 font-normal normal-case">(optional)</span></label>
                <input type="url" id="company-website" name="company-website" placeholder="https://yourcompany.com" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
              </div>
            </div>

            <div>
              <label for="project-name" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Project Name <span class="text-red-400">*</span></label>
              <input type="text" id="project-name" name="project-name" required placeholder="e.g. Copper Porphyry — Colombia" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
            </div>

            <div>
              <label for="requirements" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Describe Your Requirements <span class="text-red-400">*</span></label>
              <textarea id="requirements" name="requirements" rows="4" required maxlength="2000" placeholder="Area size, geological setting, data types available, target commodity, stage of exploration, services needed…" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary resize-none"></textarea>
            </div>

            <div>
              <label for="data-specs" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Attach Data Specs / Technical Documents <span class="text-slate-400 font-normal normal-case">(optional)</span></label>
              <input type="file" id="data-specs" name="data-specs" accept=".pdf,.doc,.docx,.xls,.xlsx,.zip,.csv,.txt" class="w-full text-sm text-slate-600 file:mr-3 file:py-2 file:px-4 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-geo-primary/10 file:text-geo-primary hover:file:bg-geo-primary/20 cursor-pointer" />
            </div>

            <div>
              <label for="news-release" class="block text-xs font-semibold uppercase tracking-wider text-slate-600 mb-1.5">Attach NR / Resource Report <span class="text-slate-400 font-normal normal-case">(optional)</span></label>
              <input type="file" id="news-release" name="news-release" accept=".pdf,.doc,.docx" class="w-full text-sm text-slate-600 file:mr-3 file:py-2 file:px-4 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-geo-primary/10 file:text-geo-primary hover:file:bg-geo-primary/20 cursor-pointer" />
            </div>

            <button type="submit" class="w-full bg-geo-gold text-white py-3 rounded-lg font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors mt-2 cursor-pointer">
              Submit Inquiry
            </button>

            <p class="text-slate-400 text-xs text-center leading-relaxed">
              🔒 Submitted securely to <strong>info@geoexplorationllc.com</strong>. All submissions are covered by our standard data security protocols and strict confidentiality.
            </p>
          </form>
        </div>

        <!-- Left: Contact info + pitch — ORDER SECOND on mobile -->
        <div class="order-2 lg:order-1">
          <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Project Inquiry</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-5 leading-tight">Tell Us About Your Project</h2>
          <p class="text-slate-300 leading-relaxed mb-5 text-sm md:text-base">
            Whether you need end-to-end exploration consulting, a CAGE-IN re-interpretation, a compliant resource report, or specific technical expertise — we'll review your inquiry and respond within 2 working days with a tailored proposal. We are happy to <a href="#cal-inline-embed" class="text-geo-gold underline underline-offset-2 hover:text-amber-400 transition-colors">schedule a call</a> to discuss your projects.
          </p>
          <ul class="space-y-2.5 text-slate-300 text-sm mb-8">
            {[
              'Pricing scales with project scope, geological complexity, and data volume',
              'Steeply discounted rates for long-term retainer arrangements',
              'NI 43-101 and JORC compliant reporting available',
              'Custom response within 2 working days of inquiry',
            ].map(item => (
              <li class="flex items-start gap-3"><span class="text-geo-gold mt-0.5 shrink-0">→</span>{item}</li>
            ))}
          </ul>

          <!-- Office Cards — hidden on mobile to reduce scroll -->
          <div class="hidden sm:grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
            <div class="p-5 rounded-xl border border-white/10 bg-white/5">
              <h3 class="font-semibold text-geo-gold mb-2 text-xs uppercase tracking-wider">Branch Office</h3>
              <p class="text-slate-300 text-sm leading-relaxed mb-3">
                24 Rue Loiselle<br />
                Les Coteaux, QC<br />
                Canada J7X 0A9
              </p>
              <a href="mailto:info@geoexplorationllc.com" class="text-geo-gold text-sm font-medium hover:text-amber-400 transition-colors break-all">
                info@geoexplorationllc.com
              </a>
            </div>
            <div class="p-5 rounded-xl border border-white/10 bg-white/5">
              <h3 class="font-semibold text-geo-gold mb-2 text-xs uppercase tracking-wider">Head Office</h3>
              <p class="text-slate-300 text-sm leading-relaxed mb-3">
                1310 Amethyst, My Home Jewel<br />
                Miyapur, Hyderabad<br />
                India 500049
              </p>
              <a href="mailto:info@geoexplorationllc.com" class="text-geo-gold text-sm font-medium hover:text-amber-400 transition-colors break-all">
                info@geoexplorationllc.com
              </a>
            </div>
          </div>

          <!-- Email visible on mobile only -->
          <div class="sm:hidden mb-5">
            <a href="mailto:info@geoexplorationllc.com" class="flex items-center gap-2 text-geo-gold text-sm font-medium">
              ✉ info@geoexplorationllc.com
            </a>
          </div>

          <div class="p-4 bg-white/5 rounded-xl border border-white/10 text-sm text-slate-400 leading-relaxed">
            <strong class="text-white">Data protection guaranteed.</strong> All inquiries are covered by our standard Mutual NDA and data security protocols before any project data changes hands.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Schedule a Discovery Call -->
  <section class="py-12 md:py-20 bg-geo-deep">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-3">Prefer to Talk First?</p>
        <h2 class="font-display text-3xl md:text-4xl text-white mb-4">Book a Discovery Call</h2>
        <p class="text-slate-400 max-w-xl mx-auto leading-relaxed">
          Schedule a 30-minute call directly with Dr. Amit Tripathi to discuss your project, ask technical questions, or explore how AIRE can add value to your programme.
        </p>
      </div>

      <!-- Cal.com inline embed -->
      <div id="cal-inline-embed" class="rounded-2xl overflow-hidden border border-white/10 shadow-sm min-h-[600px]"></div>
    </div>
  </section>

  <!-- Government & Institutional Enquiry -->
  <section id="government-enquiry" class="py-12 md:py-20 bg-geo-slate border-t border-white/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-3">Geological Surveys & Ministries</p>
        <h2 class="font-display text-3xl md:text-4xl text-white mb-4">Government & Institutional Enquiry</h2>
        <p class="text-slate-400 max-w-2xl mx-auto leading-relaxed">
          Planning a national or district-scale prospectivity program? Outline your program scope and funding context — we will respond with a tailored capability overview and suggest a technical scoping meeting.
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8 md:p-10">
        <form
          name="government-enquiry"
          method="POST"
          data-netlify="true"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="government-enquiry" />
          <input type="hidden" name="bot-field" class="hidden" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="gov-name" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Name *</label>
              <input type="text" id="gov-name" name="name" required maxlength="100" placeholder="Director / Dr. Jane Smith" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
            </div>
            <div>
              <label for="gov-email" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Email *</label>
              <input type="email" id="gov-email" name="email" required maxlength="100" placeholder="you@ministry.gov" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="gov-institution" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Ministry / Institution *</label>
              <input type="text" id="gov-institution" name="institution" required maxlength="150" placeholder="Ministry of Energy and Mineral Development" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
            </div>
            <div>
              <label for="gov-country" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Country / Jurisdiction *</label>
              <input type="text" id="gov-country" name="country" required maxlength="100" placeholder="e.g. Uganda, Tanzania, Senegal" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
            </div>
          </div>

          <div>
            <label for="gov-scope" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Program Scope *</label>
            <textarea id="gov-scope" name="program-scope" rows="3" required maxlength="1000" placeholder="e.g. National prospectivity mapping, district-level reconnaissance, investment promotion — area size, priority commodities, data holdings available…" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary resize-none"></textarea>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="gov-funding" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Funding Source</label>
              <select id="gov-funding" name="funding-source" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary bg-white">
                <option value="">Select…</option>
                <option>Own government budget</option>
                <option>Bilateral development agency</option>
                <option>World Bank / IDA</option>
                <option>African Development Bank</option>
                <option>Other multilateral</option>
                <option>Not yet determined</option>
              </select>
            </div>
            <div>
              <label for="gov-timeline" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">Expected Timeline</label>
              <input type="text" id="gov-timeline" name="expected-timeline" maxlength="100" placeholder="e.g. Start Q3 2025, 3-year duration" class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-geo-primary focus:ring-1 focus:ring-geo-primary" />
            </div>
          </div>

          <button type="submit" class="w-full bg-geo-primary text-white py-3.5 rounded-lg font-semibold text-sm uppercase tracking-wider hover:bg-geo-primary-dark transition-colors">
            Submit Government Enquiry →
          </button>
        </form>
      </div>
    </div>
  </section>

</PageLayout>

<script>
  // Cal.com inline embed
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === "string") {
          cal.ns[namespace] = cal.ns[namespace] || api;
          p(cal.ns[namespace], ar);
          p(cal, ["initNamespace", namespace]);
        } else p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window, "https://app.cal.com/embed/embed.js", "init");

  Cal("init", "aire-discovery", { origin: "https://cal.com" });

  Cal.ns["aire-discovery"]("inline", {
    elementOrSelector: "#cal-inline-embed",
    config: { layout: "month_view", theme: "light" },
    calLink: "dr-amit-tripathi",
  });

  Cal.ns["aire-discovery"]("ui", {
    theme: "light",
    cssVarsPerTheme: {
      light: { "cal-brand": "#0c498e" }
    },
    hideEventTypeDetails: false,
    layout: "month_view",
  });
</script>
