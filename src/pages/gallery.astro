---

<PageLayout
  title="Gallery — AI Resource Exploration"
  description="Photo gallery from AI Resource Exploration field projects spanning five continents."
>
  <!-- Page Hero -->
  <section class="relative bg-geo-slate text-white py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">In the Field</p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4">Gallery</h1>
      <p class="text-slate-400 text-lg">
        Field photography from mineral exploration projects across five continents.
      </p>
    </div>
  </section>

  <!-- Masonry gallery -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      id="gallery"
      class="pswp-gallery"
    >
      {images.map((img) => (
        <a
          href={`/assets/gallery/${img}`}
          target="_blank"
          class="relative block overflow-hidden rounded-sm mb-2 group"
        >
          <img
            src={`/assets/gallery/${img}`}
            alt="AI Resource Exploration field photography"
            class="w-full block transition-transform duration-500 group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/25 transition-colors duration-300 flex items-end p-3">
            <span class="text-white/0 group-hover:text-white/70 text-[10px] uppercase tracking-widest font-medium transition-all duration-300 translate-y-1 group-hover:translate-y-0">
              View
            </span>
          </div>
        </a>
      ))}
    </div>
    </div>
  </section>

  <style>
    #gallery { columns: 1; column-gap: 0.75rem; }
    @media (min-width: 480px) {
      #gallery { columns: 2; }
    }
    @media (min-width: 640px) {
      #gallery { columns: 3; }
    }
    #gallery a { break-inside: avoid; }
  </style>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
      // Let PhotoSwipe determine dimensions from the loaded image
      // rather than requiring data-pswp-width / data-pswp-height
    });

    // Resolve image dimensions dynamically so the lightbox
    // shows each photo at its real aspect ratio
    lightbox.addFilter('domItemData', (itemData, element) => {
      const img = element.querySelector('img');
      if (img && img.naturalWidth) {
        itemData.width = img.naturalWidth;
        itemData.height = img.naturalHeight;
      } else if (img) {
        img.addEventListener('load', () => {
          itemData.width = img.naturalWidth;
          itemData.height = img.naturalHeight;
        }, { once: true });
      }
      return itemData;
    });

    lightbox.init();
  </script>
</PageLayout>
