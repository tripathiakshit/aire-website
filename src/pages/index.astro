---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';

import heroImg from '../assets/hero-min.jpg';
import geologicalMappingImg from '../assets/geological_mapping-min.jpg';
import geospatialImg from '../assets/geospatial.jpg';
import geostatisticsImg from '../assets/geostatistics-min.png';
import cageInImg from '../assets/cage-in_pic1-min.jpg';
import goldProxyImg from '../assets/gold-proxy-index_pic1.png';
import drillDbImg from '../assets/drill-database-corrections_pic1-min.png';
import dataInterpretationImg from '../assets/ai-geo-identifying-prospects.png';
import structuralModellingImg from '../assets/structural_modelling.png';
import mineralIntelligenceImg from '../assets/mineral-intelligence.png';
import governmentProgramsImg from '../assets/government-programs.png';
import skillDevelopmentImg from '../assets/exploration-skill-development.png';
import amitTripathiImg from '../assets/amit_tripathi.jpg';
---

<PageLayout
  title="AI Resource Exploration — Redefining Resource Discovery Worldwide"
  description="AI Resource Exploration specializes in high-impact mineral exploration services backed by industry-leading technology and proven global experience."
>
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <Image
      src={heroImg}
      alt=""
      aria-hidden="true"
      widths={[640, 1024, 1920]}
      sizes="100vw"
      loading="eager"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(7,31,61,0.72) 0%, rgba(7,31,61,0.55) 100%);"></div>
    <div class="hero-breathe absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="relative z-10 text-center text-white px-6 max-w-5xl mx-auto">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-5">Global Experts in Advanced Mineral Exploration</p>
      <h1 class="font-display text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] mb-6">
        Redefining Resource<br /><em class="not-italic text-geo-secondary">Discovery</em> Worldwide
      </h1>
      <p class="text-base md:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed font-light">
        We specialize in high-impact mineral exploration services backed by industry-leading technology and proven global experience.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#services"
          class="w-full sm:w-auto px-8 py-4 rounded border-2 border-white/60 text-white font-medium text-sm uppercase tracking-wider hover:bg-white hover:text-geo-primary transition-all duration-200 text-center"
        >
          Our Services
        </a>
        <a
          href="/contact"
          class="w-full sm:w-auto px-8 py-4 rounded bg-geo-gold text-white font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors text-center"
        >
          Let's Discuss a Project — No Commitments
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-[10px] uppercase tracking-widest">Scroll</span>
      <div class="w-px h-8 bg-white/20"></div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-geo-slate text-white py-8 md:py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
        <div>
          <p class="font-display text-5xl font-bold text-geo-gold" data-count-to="30" data-count-suffix="+">30+</p>
          <p class="text-slate-400 text-xs uppercase tracking-[0.15em] mt-2">Years Experience</p>
        </div>
        <div>
          <p class="font-display text-5xl font-bold text-geo-gold" data-count-to="20" data-count-suffix="+">20+</p>
          <p class="text-slate-400 text-xs uppercase tracking-[0.15em] mt-2">Countries</p>
        </div>
        <div>
          <p class="font-display text-5xl font-bold text-geo-gold" data-count-to="60" data-count-suffix="+">60+</p>
          <p class="text-slate-400 text-xs uppercase tracking-[0.15em] mt-2">Projects</p>
        </div>
        <div>
          <p class="font-display text-5xl font-bold text-geo-gold" data-count-to="22" data-count-suffix="+">22+</p>
          <p class="text-slate-400 text-xs uppercase tracking-[0.15em] mt-2">Publications</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Referenced In bar -->
  <section class="bg-geo-deep border-b border-white/5 py-2.5 overflow-hidden">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-[10px] text-slate-400 uppercase tracking-[0.15em] whitespace-nowrap overflow-x-auto scrollbar-none">
        Public Domain Information: &nbsp;GoviEx Uranium &middot; Sunward Resources Ltd. &middot; Condoto Platinum Ltd. &middot; Mineral Exploration Academy &middot; Ticker Trax &middot; 321Gold
      </p>
    </div>
  </section>

  <!-- Publications strip -->
  <section class="bg-geo-slate border-b border-white/5 py-6">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 shrink-0">Research &amp; thought leadership</p>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
          {['Peer-Reviewed Journals', 'International Mining Conferences', 'AI & Exploration Technology', 'Mineral Policy Briefings', 'Industry Newsletters'].map(label => (
            <span class="text-xs text-slate-400 font-medium">{label}</span>
          ))}
        </div>
        <a
          href="https://www.airesourceexploration.com/publications/"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 text-xs font-semibold text-geo-secondary hover:text-geo-gold transition-colors uppercase tracking-wider whitespace-nowrap"
        >
          Browse 30+ publications →
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-12 md:py-20 bg-geo-deep">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10" data-reveal>
        <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-3">What We Do</p>
        <h2 class="font-display text-4xl md:text-5xl text-white mb-4">Our Services</h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">
          From national-scale prospectivity mapping to single-asset investor reports — purpose-built for every stage of exploration.
        </p>
      </div>

      <!-- CAGE-IN featured card -->
      <a href="/cage-in" class="group flex flex-col sm:flex-row overflow-hidden rounded-2xl border border-white/10 hover:border-geo-gold/60 hover:shadow-xl hover:shadow-black/30 transition-all duration-300 mb-6 bg-white/5" data-reveal>
        <div class="sm:w-2/5 h-52 sm:h-auto overflow-hidden flex-shrink-0">
          <Image
            src={cageInImg}
            alt="CAGE-IN — AI-Driven Mineral Targeting"
            width={600}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <div class="flex-1 p-6 sm:p-8 flex flex-col justify-between border-t-2 sm:border-t-0 sm:border-l-2 border-transparent group-hover:border-geo-gold transition-colors duration-300">
          <div>
            <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-2">Proprietary AI Technology</p>
            <h3 class="font-display text-2xl md:text-3xl text-white font-semibold mb-3 leading-snug">AI-Driven Mineral Targeting — CAGE-IN</h3>
            <p class="text-slate-400 leading-relaxed max-w-xl">
              Proprietary AI re-interpretation of your existing geological, geochemical, and geophysical data to generate precision mineral targets — shortening the exploration cycle from years to months.
            </p>
          </div>
          <p class="mt-5 text-geo-gold text-sm font-semibold uppercase tracking-wider">Explore CAGE-IN in depth →</p>
        </div>
      </a>

      <!-- Detailed service sections -->
      <div class="max-w-5xl mx-auto mt-12 space-y-16">

        <!-- Mineral Reconnaissance -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div>
            <h3 class="font-display text-2xl text-white mb-3">Mineral Reconnaissance</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">Remote sensing and field verification-based geological mapping of large areas to identify prospective targets for further investigation.</p>
            <ul class="list-disc list-inside text-slate-300 space-y-1.5 text-sm">
              <li>Base mapping in Greenfield Exploration</li>
              <li>Lithology and structure mapping at local and regional scale</li>
              <li>Underground geological and structural mapping</li>
              <li>Geochemical anomaly mapping based on assay data</li>
              <li>Mapping alteration signatures relevant to the mineral of interest</li>
              <li>Analysis and interpretation of multiple datasets for target generation</li>
              <li>Establishing structural controls of mineralization in 3D</li>
            </ul>
          </div>
          <div>
            <Image src={geologicalMappingImg} alt="Mineral Reconnaissance — geological mapping" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- GIS Integration -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div class="order-2 md:order-1">
            <Image src={geospatialImg} alt="GIS Integration — geospatial analysis" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
          <div class="order-1 md:order-2">
            <h3 class="font-display text-2xl text-white mb-3">GIS Integration</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">Integrating data from multiple sources into a single unified database, enabling comprehensive spatial analysis across all exploration datasets.</p>
            <ul class="list-disc list-inside text-slate-300 space-y-1.5 text-sm">
              <li>Dedicated team highly experienced in satellite data interpretation — including high-resolution and hyper-spectral image interpretation</li>
              <li>Specialist capability in lithostructural interpretation combined with alteration and mineral mapping</li>
              <li>Large portfolio covering a wide range of commodities in diverse geological environments</li>
              <li>High-resolution imagery examination for geological mapping and mine planning</li>
            </ul>
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- Turnkey Exploration & Resource Modelling -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div>
            <h3 class="font-display text-2xl text-white mb-3">Turnkey Exploration &amp; Resource Modelling</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">High-resolution mapping, sampling, and geophysics combined with predictive modelling and drill planning. Full drilling management including logging, sampling, QA-QC, cross sections, and resource models.</p>
            <ul class="list-disc list-inside text-slate-300 space-y-1.5 text-sm">
              <li>3D modelling of major structures, fracture zones, lithologies, ore volumes, and alteration zones</li>
              <li>Converting the exploration drilling database into 3D models</li>
              <li>Mineralization target generation by litho-structure pattern study in 3D</li>
              <li>Modelling the distribution pattern of ore bodies</li>
              <li>Resource modelling using geological, geochemical and geophysical data</li>
              <li>3D block modelling for resource estimation</li>
            </ul>
          </div>
          <div>
            <Image src={geostatisticsImg} alt="Turnkey Exploration and Resource Modelling" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- Exploration Technologies -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div class="order-2 md:order-1">
            <Image src={dataInterpretationImg} alt="Exploration Technologies" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
          <div class="order-1 md:order-2">
            <h3 class="font-display text-2xl text-white mb-3">Exploration Technologies</h3>
            <p class="text-slate-300 leading-relaxed">Developing and deploying proprietary technology tools for efficient, AI-driven, and eco-friendly exploration — increasing process efficiency while reducing environmental impact.</p>
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- Integrated Data Interpretation -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div>
            <h3 class="font-display text-2xl text-white mb-3">Integrated Data Interpretation</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">Proven proprietary technology for integrating historical data, known mineralization data, and geological and geophysical datasets for precise mineral targeting over large areas.</p>
            <ul class="list-disc list-inside text-slate-300 space-y-1.5 text-sm">
              <li>Processing and interpretation of aeromagnetic and radiometric data to understand mineralization controls</li>
              <li>Integration of RS and geophysical datasets (2D and 3D) for target generation</li>
              <li>Prioritization of exploration targets</li>
              <li>Proprietary CAGE-IN technology for geological and geophysical data integration and enhanced interpretation</li>
            </ul>
          </div>
          <div>
            <Image src={structuralModellingImg} alt="Integrated Data Interpretation" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- Mineral Intelligence -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div class="order-2 md:order-1">
            <Image src={mineralIntelligenceImg} alt="Mineral Intelligence" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
          <div class="order-1 md:order-2">
            <h3 class="font-display text-2xl text-white mb-3">Mineral Intelligence</h3>
            <p class="text-slate-300 leading-relaxed">Remote sensing and drone-based surveys of mining areas for change detection of toxic pollutants, illegal mining activities, and production monitoring.</p>
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- Government & National Programs -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div>
            <h3 class="font-display text-2xl text-white mb-3">Government &amp; National Programs</h3>
            <p class="text-slate-300 leading-relaxed mb-4">National-scale prospectivity mapping for geological surveys, ministries, and governments. CAGE-IN converts existing aeromagnetic, radiometric, and remote sensing datasets into 200+ ranked mineral targets — packaged as investor-ready prospectus materials to attract exploration FDI.</p>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">Results-as-a-Service: payment only on accepted deliverables. Includes embedded capacity building for government geoscientists and full data sovereignty.</p>
            <a href="/cage-in#national-scale" class="inline-flex items-center gap-1.5 text-geo-gold text-xs font-semibold uppercase tracking-wider hover:text-amber-400 transition-colors">Learn more about national-scale programs →</a>
          </div>
          <div>
            <Image src={governmentProgramsImg} alt="Government and National Programs" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
        </div>

        <hr class="border-white/10" />

        <!-- Skill Development in Exploration -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center" data-reveal>
          <div class="order-2 md:order-1">
            <Image src={skillDevelopmentImg} alt="Skill Development in Exploration" width={600} class="rounded-xl shadow-lg w-full object-cover" />
          </div>
          <div class="order-1 md:order-2">
            <h3 class="font-display text-2xl text-white mb-3">Skill Development in Exploration</h3>
            <p class="text-slate-300 mb-4 leading-relaxed">We build the capacity of clients' in-house teams by embedding high-level geological expertise directly on site. As part of this service, we have developed custom data entry tools with:</p>
            <ul class="list-disc list-inside text-slate-300 space-y-1.5 text-sm">
              <li>HTML-based tools using CSS / PHP / JS</li>
              <li>Dropdown lists defining permitted values to eliminate operator errors</li>
              <li>Validation rules updated as data is entered</li>
              <li>Operator access restricted to current working files</li>
            </ul>
          </div>
        </div>


      </div>
    </div>
  </section>

  <!-- Third-party recognition quote strip -->
  <section class="py-8 md:py-12 bg-geo-slate border-y border-white/8" data-reveal>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-display text-xl md:text-2xl text-white italic leading-relaxed mb-4">
        "Internationally recognised and referenced in gold, diamond, and iron ore exploration works."
      </p>
      <p class="text-xs text-slate-500 uppercase tracking-widest">— Referenced by Ticker Trax (Thom Calandra) and 321Gold (Bob Moriarty)</p>
    </div>
  </section>

  <!-- Trusted Expertise -->
  <section class="py-12 md:py-20 bg-geo-deep">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-12" data-reveal>
        <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-3">Why Choose Us</p>
        <h2 class="font-display text-3xl md:text-5xl text-white mb-4">Trusted Expertise in Every Layer of the Earth</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
        <div class="flex flex-col gap-3 p-4 md:p-6 rounded-xl border border-white/8 hover:border-geo-gold/50 hover:bg-white/5 transition-all duration-200">
          <div class="w-9 h-9 md:w-12 md:h-12 rounded-lg bg-geo-primary/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-geo-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-display text-sm md:text-lg text-white font-semibold leading-snug">Expert-Led Geoscience Teams</h3>
          <p class="hidden md:block text-slate-400 text-sm leading-relaxed">Our team consists of seasoned geologists, geophysicists, and data scientists with decades of combined field experience.</p>
        </div>
        <div class="flex flex-col gap-3 p-4 md:p-6 rounded-xl border border-white/8 hover:border-geo-gold/50 hover:bg-white/5 transition-all duration-200">
          <div class="w-9 h-9 md:w-12 md:h-12 rounded-lg bg-geo-primary/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-geo-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display text-sm md:text-lg text-white font-semibold leading-snug">Cutting-Edge Technologies</h3>
          <p class="hidden md:block text-slate-400 text-sm leading-relaxed">We deploy the latest geophysical tools, geospatial data platforms, and proprietary AI-powered systems like CAGE-IN.</p>
        </div>
        <div class="flex flex-col gap-3 p-4 md:p-6 rounded-xl border border-white/8 hover:border-geo-gold/50 hover:bg-white/5 transition-all duration-200">
          <div class="w-9 h-9 md:w-12 md:h-12 rounded-lg bg-geo-primary/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-geo-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
          <h3 class="font-display text-sm md:text-lg text-white font-semibold leading-snug">Global Field Experience</h3>
          <p class="hidden md:block text-slate-400 text-sm leading-relaxed">From North America to Africa, our projects span varied geological terrains and regulatory environments across 15+ countries.</p>
        </div>
        <div class="flex flex-col gap-3 p-4 md:p-6 rounded-xl border border-white/8 hover:border-geo-gold/50 hover:bg-white/5 transition-all duration-200">
          <div class="w-9 h-9 md:w-12 md:h-12 rounded-lg bg-geo-primary/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-geo-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <h3 class="font-display text-sm md:text-lg text-white font-semibold leading-snug">End-to-End Project Support</h3>
          <p class="hidden md:block text-slate-400 text-sm leading-relaxed">We manage all stages — from planning and permitting to execution and reporting — ensuring seamless project delivery.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technologies Section -->
  <section class="py-12 md:py-20 bg-geo-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.25em] mb-3" data-reveal>Competitive Advantage</p>
          <h2 class="font-display text-4xl md:text-5xl text-white mb-6 leading-tight">Proprietary<br /><span class="text-gradient">Technologies</span></h2>
          <p class="text-slate-300 text-lg leading-relaxed mb-4">
            AI Resource Exploration has developed a suite of proprietary technologies that go beyond conventional exploration methods. Our CAGE-IN system, Gold Proxy Index, and Spectral Classification tools give clients a decisive edge.
          </p>
          <p class="text-slate-400 leading-relaxed mb-8">
            These innovations allow us to identify targets in well-explored areas, predict gold grades in coarse-gold deposits, and classify mineral prospects over large regions using spectral signatures.
          </p>
          <a
            href="/technologies"
            class="inline-block bg-geo-gold text-white px-7 py-3.5 rounded font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors"
          >
            Explore Our Technologies
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <Image src={cageInImg} alt="CAGE-IN Technology" width={400} class="rounded-xl shadow-md w-full h-36 md:h-44 object-cover" />
          <Image src={goldProxyImg} alt="Gold Proxy Index" width={400} class="rounded-xl shadow-md w-full h-36 md:h-44 object-cover md:mt-6" />
          <Image src={drillDbImg} alt="Drill Database" width={400} class="rounded-xl shadow-md w-full h-36 md:h-44 object-cover" />
          <Image src={dataInterpretationImg} alt="Data Interpretation" width={400} class="rounded-xl shadow-md w-full h-36 md:h-44 object-cover md:mt-6" />
        </div>
      </div>
    </div>
  </section>

  <!-- Driving Smarter Exploration -->
  <section class="py-12 md:py-20 bg-geo-deep">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
