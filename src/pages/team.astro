---
import PageLayout from '../layouts/PageLayout.astro';

const team = [
  { name: 'Dr. Amit Tripathi', role: 'Founder & Principal Consultant', detail: 'Exploration geologist with three decades of experience across 20+ countries. PhD in Structural Geology; AusIMM member. Led the programme that tripled the Titiribi Cu-Au porphyry resource (Colombia) to 13 Moz Au-eq. Discovered the 175M lb Madaouela uranium deposit (Niger) and the West Nile nickel laterite deposit (Uganda). Former Research Fellow, Department of Atomic Energy of India and CSIR India. Author of several peer-reviewed publications and inventor of the CAGE-IN technology.', location: '' },
  { name: 'Ankit Tripathi', role: 'General Manager', detail: 'Environmental Scientist and Business Management Specialist overseeing operations and client engagement.', location: '' },
  // Advisors
  { name: 'Dr. V.N. Vasudev', role: 'Advisor — Economic Geology', detail: 'Ph.D. Economic Geology with 45 years in exploration and research. Discovered multiple +1 Moz gold deposits in India and the Ingaldhal Copper Mine extensions. Explored across 42 countries for gold, copper, lead, zinc, nickel, iron ore, and PGE. Co-founder of Geomysore Services; former CEO of MPXG Exploration (India); Assistant Editor, Journal of the Geological Society of India.', location: 'India' },
  { name: 'Chris Ainsworth', role: 'Advisor — Exploration', detail: 'M.Sc. Mineral Exploration with 33 years in exploration and mining geology across Africa. Discovered a 1.5 Bt bauxite deposit in Cameroon. Expertise in underground and peripheral exploration, structural geology, lateritic Ni, layered igneous complex Ni-PGE, kimberlite diamond, and compliant QA/QC. Former Chief Geologist/Mineral Resource Manager at Randgold Resources/Syama gold mine, Mali. Founder, Chris Ainsworth Consulting; Principal Consultant, MPXG Exploration.', location: 'South Africa' },
  { name: 'Roisin Goodman', role: 'Advisor — Exploration', detail: 'B.Sc Geology with 36 years in exploration and consulting. AIM, AIM+ and NI 43-101 compliant reporting and certification specialist. Expertise spans orogenic gold, lithogeochemistry, pegmatite Sn-W-COLTAN, MVT base metals, Ni-laterite, and geothermal exploration across Ireland, Tanzania, Ghana, Greenland, Uganda, and Latin America. Former Exploration Manager at Samta Mining and Minerals (Uganda); Project Manager, SLR/CSA Group, Ireland; Project Geologist, Lisheen Zn-Pb mine, Ireland.', location: 'Ireland' },
  { name: 'A.P.S. Chandi', role: 'Advisor — Mining', detail: 'Mining Engineer with 34 years in underground mining. Holds a 1st class Mine Manager\'s Certificate of Competency (Metalliferous, unrestricted) and a B.Eng. Mining from University of Jodhpur plus CESPROMING from École des Mines de Paris. Seven years at the 21,000 tpm Al Amar mine in Saudi Arabia; 24 years in underground Lead and Zinc mines of HZL (India) including Head of Planning at the 3,000 TPD Rajpura Dariba mine. Recognised Qualified Person for mining projects.', location: 'India' },
  { name: 'Prof. Bhabesh C Sarkar', role: 'Advisor — Resource Evaluation & Geostatistics', detail: "45+ years in geostatistics across industry and elite academia. Currently Professor of Geostatistics at IIT Bombay; formerly Professor (HAG) at IIT(ISM) Dhanbad and Director at AICTE. Expert in mineral resource evaluation and computerisation of mining geostatistics. Author of 128+ publications, 8 books (including a widely cited Elsevier title), and 13 patents. National Geoscience Award; Distinguished Alumnus, IIT Kharagpur.", location: 'India' },
  // Technical specialists
  { name: 'Mamadouba Yansane', role: 'Geology Specialist', detail: 'Part of the team that discovered world-class iron ore reserves (2011–2013). Supervised drilling programs for Simandou pre-feasibility and feasibility studies at Rio Tinto. Experience in gold, iron, bauxite, and base metals across West Africa. Certified in Project Management (University of British Columbia). 23 years in exploration.', location: '' },
  { name: 'Krishna Prasad', role: 'Geophysics Specialist', detail: 'M.Sc.(Tech) Geophysics with 22 years of exploration experience across base metals, gold, PGE, hydrocarbons, and geotechnical applications. Methods include ground magnetics, time-domain EM, gravity, electrical methods, and 2D/3D seismic. Projects span India, Tanzania, Sudan, Uganda, DRC, Guinea, and the USA.', location: '' },
  { name: 'Dr. Vikas Srivastava', role: 'Remote Sensing & GIS', detail: 'Ph.D. Remote Sensing and GIS with 14 years in geological, geophysical, and geospatial exploration management. Proficient in Geosoft Oasis Montaj, ArcGIS, Micromine, ERDAS Imagine, ENVI, Python, MATLAB, and FORTRAN. Former roles at SRK Consulting, IIT BHU, Rolta, and Samta Group.', location: '' },
  { name: 'Ibrahim Aouami', role: 'Senior Geologist', detail: 'M.Sc. Geology with 17 years in exploration. Exploration Site Manager for Goviex Uranium (2008–2015) during the discovery of 165+ Mlb U₃O₈ in Niger; supervised over 250,000 m of drilling at Madaouela. Experience across uranium, nickel laterite, and gold projects in Niger, French Guyana, and DRC.', location: '' },
  { name: 'N. Ganesh', role: 'Structural Geologist', detail: 'Specialist in structural controls on mineralisation and project-scale geological modelling.', location: '' },
  { name: 'Niki Kiza Oliver', role: 'Geologist', detail: 'Broad experience across multiple gold exploration projects in Africa and beyond.', location: '' },
  { name: 'Dolma Ray', role: 'Resource Modeller', detail: 'Specialist in 3D resource modelling and geostatistical analysis for compliant resource estimation.', location: '' },
  { name: 'Timothy Kwihangana', role: 'Country Director — Uganda', detail: 'Leads on-ground operations and stakeholder engagement for AIRE\'s Uganda projects.', location: 'Uganda' },
];
---

<PageLayout
  title="Our Team — AI Resource Exploration"
  description="Meet the AIRE team — specialist geologists, geophysicists, remote sensing experts, resource modellers, and advisors delivering world-class mineral exploration."
>
  <!-- Page Hero -->
  <section class="relative bg-geo-slate text-white py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">The People Behind Our Work</p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4">Our Team</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        AIRE engages a network of specialist geologists, geophysicists, remote sensing experts, resource modellers, and senior advisors — 15 specialists across five continents.
      </p>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {team.map(({ name, role, detail, location }) => {
          const initials = name.split(' ').filter(w => !w.startsWith('(')).map(w => w[0]).join('').slice(0, 2).toUpperCase();
          return (
            <div class="flex gap-4 p-6 bg-white rounded-xl border border-slate-100 hover:border-geo-gold/30 hover:shadow-md transition-all">
              <div class="shrink-0 w-12 h-12 rounded-full bg-geo-primary/10 flex items-center justify-center text-geo-primary font-bold text-sm">
                {initials}
              </div>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-0.5">
                  <p class="font-semibold text-geo-primary text-sm">{name}</p>
                  {location && <span class="text-slate-400 text-xs">· {location}</span>}
                </div>
                <p class="text-geo-gold text-xs font-medium uppercase tracking-wide mb-2">{role}</p>
                <p class="text-slate-500 text-sm leading-relaxed">{detail}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-geo-slate text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Work With Us</p>
      <h2 class="font-display text-4xl font-bold mb-6">Ready to discuss your project?</h2>
      <a href="/contact" class="inline-block bg-geo-gold text-white px-10 py-4 rounded font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors">
        Get in Touch
      </a>
    </div>
  </section>
</PageLayout>
