---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import TechCard from '../components/TechCard.astro';

import cageInImg from '../assets/cage-in_pic1-min.jpg';
import goldProxyImg from '../assets/gold-proxy-index_pic1.png';
import goldProxy2Img from '../assets/gold-proxy-index_pic2.png';
import drillDbImg from '../assets/drill-database-corrections_pic1-min.png';
import drillDb2Img from '../assets/drill-database-corrections_pic2.png';
---

<PageLayout
  title="Technologies — AI Resource Exploration"
  description="Proprietary technologies developed by AI Resource Exploration: CAGE-IN, Gold Proxy Index, and Drill Database Corrections."
>
  <!-- Page Hero -->
  <section class="relative bg-geo-slate text-white py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 30px 30px;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-geo-gold text-xs font-semibold uppercase tracking-[0.3em] mb-4">Our Innovations</p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4">Proprietary Technologies</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Innovations that give our clients a decisive advantage in mineral exploration.
      </p>
    </div>
  </section>

  <!-- Technologies -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 divide-y divide-gray-200">

      <!-- CAGE-IN -->
      <div>
        <TechCard
          title="CAGE-IN: Constrained Area Gridding for Enhanced Interpretation"
          description={`
            <p class="mb-3">CAGE-IN technology enhances existing geophysical data to identify additional targets even in well-explored areas.</p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>Applicable to several mineral occurrences</li>
              <li>Demonstrated in porphyry, epithermal, and skarn deposit types</li>
              <li>Can be applied on pre-existing surveys as well as in conjunction with fresh acquisition</li>
              <li>CAGE-IN is an integrated interpretation approach that works increasingly well when geological maps, soil/rock geochem data, structural maps, and locations of historical/artisanal workings are available</li>
            </ul>
          `}
          image={cageInImg}
          downloadUrl="/assets/downloads/20170214-CAGEIN_GeoExploration_Presentation.pdf"
          downloadLabel="Download CAGE-IN Presentation"
          reversed={false}
        />
      </div>

      <!-- Gold Proxy Index -->
      <div>
        <TechCard
          title="Gold Proxy Index: Solving the Nugget Effect"
          description={`
            <p class="mb-3">Coarse gold deposits are a mineral engineer's dream but an exploration geologist's nightmare. The extreme sampling challenges of the <strong>"nugget effect"</strong> — where erratic gold grain distribution makes grade estimation by drilling statistically unreliable — have long frustrated exploration teams and wasted drill budgets on excess infill campaigns.</p>
            <p class="mb-3">To solve this, we developed the <strong>Gold Proxy Index</strong>: a methodology that maps and analyses the reliable structural, geological, analytical, and mathematical footprints that act as proxies for gold deposition. Rather than chasing gold directly, we model the system that concentrates it.</p>
            <p class="mb-3">The result is a statistically defensible model that empowers your team to target and assess erratic gold mineralisation with significantly higher confidence — without blowing your entire budget on excess infill drilling.</p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>Applicable to coarse-gold and nuggety deposits of any style</li>
              <li>Combines structural proximity, ore chemistry, and pathfinder element distributions</li>
              <li>Produces a grade-proxy map your QP can use as input for resource reporting</li>
              <li>Reduces infill drilling requirements while improving resource confidence category</li>
            </ul>
          `}
          image={goldProxyImg}
          reversed={true}
        />
        <div class="pb-12 -mt-4">
          <Image src={goldProxy2Img} alt="Gold Proxy Index Chart" width={600} class="rounded-xl shadow-md max-w-lg mx-auto w-full object-cover" />
        </div>
      </div>

      <!-- Drill Database Corrections -->
      <div>
        <TechCard
          title="Drill Database Corrections"
          description={`
            <p class="mb-3">Common sources of error in drill databases are data entry errors. We have developed several multi-level QA/QC routines that clean drilling databases of errors by flagging locations of potential errors.</p>
            <ul class="list-disc list-inside space-y-1 text-sm">
              <li>Clean databases ready for modelling</li>
              <li>Data validation within defined ranges</li>
              <li>Comparing data records with 3-element and 5-element averages of numerical data</li>
              <li>Comparing multiple entries of text data</li>
              <li>Deviations flagged for supervisory verification</li>
            </ul>
          `}
          image={drillDbImg}
          reversed={false}
        />
        <div class="pb-12 -mt-4">
          <Image src={drillDb2Img} alt="QA/QC Tool" width={600} class="rounded-xl shadow-md max-w-lg mx-auto w-full object-cover" />
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-geo-slate text-white relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold mb-4">Interested in Our Technologies?</h2>
      <p class="text-slate-400 mb-8">Contact us to learn how these proprietary tools can be applied to your exploration project.</p>
      <a href="/contact" class="inline-block bg-geo-gold text-white px-10 py-4 rounded font-semibold text-sm uppercase tracking-wider hover:bg-amber-500 transition-colors">
        Get in Touch
      </a>
    </div>
  </section>
</PageLayout>
